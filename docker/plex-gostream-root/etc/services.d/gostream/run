#!/usr/bin/with-contenv bash
set -euo pipefail

CONFIG_PATH="${MKV_PROXY_CONFIG_PATH:-/config/config.json}"
ROOT_PATH="${GOSTREAM_ROOT_PATH:-/config/gostream}"
SOURCE_PATH="${GOSTREAM_SOURCE_PATH:-/mnt/gostream-mkv-real}"
MOUNT_PATH="${GOSTREAM_MOUNT_PATH:-/mnt/gostream-mkv-virtual}"
STATE_DIR="${GOSTREAM_STATE_DIR:-$ROOT_PATH/STATE}"
LOG_DIR="${GOSTREAM_LOG_DIR:-$ROOT_PATH/logs}"

mkdir -p "$SOURCE_PATH" "$MOUNT_PATH" "$ROOT_PATH" "$STATE_DIR" "$LOG_DIR"

if [ ! -f "$CONFIG_PATH" ]; then
  echo "[gostream] Missing required config file at $CONFIG_PATH" >&2
  exit 1
fi

# Best-effort cleanup of stale FUSE mount.
if mountpoint -q "$MOUNT_PATH" 2>/dev/null; then
  if grep -q " $MOUNT_PATH fuse" /proc/mounts 2>/dev/null; then
    echo "[gostream] Stale FUSE mount detected at $MOUNT_PATH, cleaning up..." >&2
    fusermount3 -uz "$MOUNT_PATH" 2>/dev/null || true
  fi
fi

echo "[gostream] Starting (ROOT=$ROOT_PATH SOURCE=$SOURCE_PATH MOUNT=$MOUNT_PATH)" >&2
exec /usr/local/bin/gostream --path "$ROOT_PATH" "$SOURCE_PATH" "$MOUNT_PATH"
